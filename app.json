{
  "expo": {
    "name": "PSGovindpur",
    "slug": "PSGovindpur",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "in.psgovindpur.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0F2347"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-logo.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#EFE9D9"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "24b8f228-99d1-4010-b3ac-55f51e05b3b5"
      }
    }
  }
}
